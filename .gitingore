*.renderTexture.meta
*.lightmapParameters.meta
*.cubemap.meta
*.flare.meta
*.terrainData.meta
*.tree.meta
*.brush.meta

# Unity built-in packages
*.unitypackage

# Unity cache folder
[Ee]xports/
[Uu]nity[Gg]enerated/
[Ww]eb[Ss]ocket[Tt]emp/

# Addressable assets
[Ll]ibrary/[Aa]ddressable[Aa]ssets[Dd]ata/

# Code Coverage
[Ll]ibrary/[Cc]ode[Cc]overage/

# Test files
*.asmdef.meta
*.asmdef

# Rider
.Rider/

# Memory dumps
*.memdump
*.memorydump
*.memsave
*.memorysave

# Audio files
*.tmpAudio

# Asset import errors
