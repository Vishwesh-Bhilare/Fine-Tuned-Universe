*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D Generated File On Crash Reports
sysinfo.txt

# Unity3D Build and Crash reports
*.unitypackage

# Autogenerated VS solution files
*.slnx
*.csproj.meta

# Unity cache files
*.cs.meta
*.js.meta
*.boo.meta
*.asset.meta
*.prefab.meta
*.unity.meta
*.mat.meta
*.controller.meta
*.anim.meta
*.overrideController.meta
*.physicMaterial.meta
